# ── Backend Services ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://codeMind-ollama:11434
QDRANT_URL=http://codeMind-qdrant:6333
FASTAPI_URL=http://codeMind-backend:8000

# ── Models ────────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5-coder:3b
EMBEDDING_MODEL=BAAI/bge-m3
QDRANT_COLLECTION=source_chunks

# ── Processing ────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=5

# ── Storage ───────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads

# ── Upload Limits ─────────────────────────────────────────────────
UPLOAD_CHUNK_SIZE=1048576       # 1MB
MAX_FILE_SIZE=1073741824        # 1GB
MAX_FILES_PER_REQUEST=5         # 요청당 최대 파일 개수

# ── Cookie ────────────────────────────────────────────────────────
COOKIE_PASSWORD=itsmartCodeMind
